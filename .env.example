# Analytics — set the ones you use; leave the rest blank to disable.
# All are read at build time by Vite (must start with VITE_).

# Google Analytics 4 measurement ID (e.g. G-XXXXXXX)
VITE_GA4_ID=

# Google Tag Manager container ID (e.g. GTM-XXXXXX)
VITE_GTM_ID=

# Microsoft Clarity project ID
VITE_CLARITY_ID=

# PostHog project API key (phc_...) and host (defaults to https://us.i.posthog.com)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=